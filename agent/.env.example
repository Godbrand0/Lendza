# ─── Network ────────────────────────────────────────────────────────────────
RPC_URL=https://devnet.zama.ai          # Zama devnet or your Sepolia RPC

# ─── Contract Addresses ──────────────────────────────────────────────────────
VAULT_ADDRESS=<ConfidentialVault address>
AUCTION_ADDRESS=<DutchAuction address>
CUSDC_ADDRESS=<ConfidentialDebt (cUSDC) token address>

# ─── Agent Wallets (use separate funded keys per role) ───────────────────────
MONITOR_PRIVATE_KEY=0x...    # needs ETH for gas (requestLiquidationCheck)
BIDDER_PRIVATE_KEY=0x...     # needs ETH for auction deposits + gas

# ─── x402 Server ─────────────────────────────────────────────────────────────
# Wallet authorised to call vault.grantAgentAccess() (owner or whitelisted op)
ADMIN_PRIVATE_KEY=0x...

# Address that receives USDC fee payments from agents
PAYMENT_ADDRESS=0x...

# Fee per (agent, borrower) grant — 6-decimal USDC units
# 10000000 = 10 USDC  |  5000000 = 5 USDC  |  1000000 = 1 USDC
X402_FEE_USDC=10000000

# Port the x402 server listens on
SERVER_PORT=3001

# ─── Agent x402 Client (set in agent scripts, not the server) ────────────────
X402_SERVER_URL=http://localhost:3001
